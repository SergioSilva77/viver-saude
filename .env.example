# ── Admin panel credentials ────────────────────────────────
# Configure also in apps/admin/.env (Vite needs VITE_ prefix)
VITE_ADMIN_EMAIL=admin@vivervsaude.com.br
VITE_ADMIN_PASSWORD=

# ── App URLs ──────────────────────────────────────────────
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
PORT=4000

# ── Supabase ───────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (frontend Vite) ───────────────────────────────
# Variáveis expostas ao browser precisam do prefixo VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe ─────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# IDs de preço (Products > seu produto > Add price)
STRIPE_PRICE_ID_NIVEL1=
STRIPE_PRICE_ID_NIVEL2=
STRIPE_PRICE_ID_NIVEL3=

# ── Anthropic Claude ───────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
# Modelos disponíveis: claude-haiku-3-5 | claude-sonnet-4-5 | claude-opus-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Google Gemini ──────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
# Modelos disponíveis: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── AI Provider ativa ──────────────────────────────────────
# Qual provedor a API usará: claude | gemini
AI_PROVIDER=claude
